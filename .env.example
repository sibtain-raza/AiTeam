# All 8 agents run via the Claude Agent SDK, authenticated through the
# `claude` CLI's own login (`claude auth login`) — no API key needed here.
# Optional model override for all agents (default: sonnet — a claude CLI
# alias for the latest Sonnet model, chosen over Claude Code's own
# Opus-tier default for cost, since one run consumes many real sessions):
# LOOPER_CODE_MODEL=

# Optional: directory for transcripts/workspace/checkpoints (default: ./output)
# LOOPER_OUTPUT_DIR=

# --- Everything below is unused by default ---
# Read only by src/looper/config.py, which is currently unwired dead code
# kept in case the pipeline is ever pointed back at a raw-API-key provider
# (AnthropicChatCompletionClient/OpenAIChatCompletionClient) instead of the
# `claude` CLI. Setting these has no effect unless that path is re-wired.
LOOPER_PROVIDER=anthropic
# LOOPER_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
