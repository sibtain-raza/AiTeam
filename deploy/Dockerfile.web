# Looper web UI: build the Vite/React app, serve the static bundle via nginx.
#
# Build from the REPO ROOT:
#   docker build -f deploy/Dockerfile.web -t looper-web \
#     --build-arg VITE_API_BASE=http://localhost:8000 .
#
# VITE_API_BASE is inlined into the browser bundle at BUILD time and must be
# reachable from the end-user's BROWSER (not container-to-container) — same
# constraint as any Vite env var. The default matches the compose file's
# published API port.
FROM node:22-alpine AS build
WORKDIR /build
COPY web/package.json web/package-lock.json ./
RUN npm ci
COPY web/ .
ARG VITE_API_BASE=http://localhost:8000
ENV VITE_API_BASE=${VITE_API_BASE}
RUN npm run build

FROM nginx:1.27-alpine
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /build/dist /usr/share/nginx/html
EXPOSE 80
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD wget -q --spider http://localhost:80/ || exit 1
